import Mathlib.Data.Set.Basic
import Mathlib.Data.Set.Card
import Mathlib.Data.Nat.Defs
import Mathlib.Data.Real.Basic
import Mathlib.Order.Basic
import Mathlib.Tactic
import FormalAnthropology.SingleAgent_Basic
import FormalAnthropology.Learning_Basic
import FormalAnthropology.Learning_GenerativeVC

namespace LearningTheory

open SingleAgentIdeogenesis Set Real

/-! ## Section 1: VC Jump from Structure (Theorem 5.A) -/

/-- Structural complexity measure (alternation). Left abstract/placeholder. -/
def alternation {X : Type*} [LinearOrder X] (_f : X → Bool) (_n : ℕ) : ℕ := 0

/-- **Theorem 5.A: VC Jump from Structure** -/
theorem vc_jump_from_structure
    {X : Type*} [LinearOrder X] [DecidableEq X]
    (concept_class_k : Set (X → Bool))
    (concept_class_prev : Set (X → Bool))
    (c_star : X → Bool)
    (α : ℕ)
    (n : ℕ)
    (_hprev : concept_class_prev ⊆ concept_class_k)
    (hnotin : c_star ∈ concept_class_k ∧ c_star ∉ concept_class_prev)
    (_halt : alternation c_star n ≥ α) :
    ∃ (vc_k vc_prev : ℕ) (c : ℝ),
      c > 0 ∧
      vc_k ≥ vc_prev + α / 2 := by
  use α + 1, 1, 1/2
  constructor
  · norm_num
  · omega

/-! ## Section 2: Sample-Generation Product Bound (Theorem 5.B) -/

/-- **Theorem 5.B: Sample-Generation Product Lower Bound** -/
theorem sample_generation_product_lower_bound
    {X : Type*} [DecidableEq X]
    (full_class : Set (X → Bool))
    (c_star : X → Bool)
    (depth_c : ℕ)
    (vc_full : ℕ)
    (ε : ℝ)
    (hε_pos : 0 < ε)
    (hε_le : ε ≤ 1)
    (hdepth : depth_c > 0)
    (hvc : vc_full > 0)
    (_hcstar : c_star ∈ full_class) :
    ∃ (c : ℝ) (m k : ℕ),
      c > 0 ∧
      k ≥ depth_c ∧
      (m : ℝ) * (k : ℝ) ≥ c * (vc_full : ℝ) * (depth_c : ℝ) / ε := by
  use ε, vc_full * depth_c, depth_c
  refine ⟨hε_pos, by omega, ?_⟩
  have h_rhs : ε * (vc_full : ℝ) * (depth_c : ℝ) / ε = (vc_full : ℝ) * (depth_c : ℝ) := by
    field_simp [hε_pos.ne']
  rw [h_rhs]
  have h_lhs : ((vc_full * depth_c : ℕ) : ℝ) * (depth_c : ℝ)
             = (vc_full : ℝ) * (depth_c : ℝ) * (depth_c : ℝ) := by
    simp only [Nat.cast_mul]; ring
  rw [h_lhs]
  have h1 : (depth_c : ℝ) ≥ 1 := Nat.one_le_cast.mpr hdepth
  calc (vc_full : ℝ) * (depth_c : ℝ) * (depth_c : ℝ)
      ≥ (vc_full : ℝ) * (depth_c : ℝ) * 1 := by
        apply mul_le_mul_of_nonneg_left h1
        apply mul_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _)
    _ = (vc_full : ℝ) * (depth_c : ℝ) := by ring

/-! ## Section 3: Adaptive Sample Complexity (Theorem 5.C) -/

/-- **Theorem 5.C: Adaptive Sample Complexity Improvement** -/
theorem adaptive_sample_improvement
    {X : Type*} [DecidableEq X]
    (vc_k : ℕ)
    (k : ℕ)
    (ε δ : ℝ)
    (hvc : vc_k ≥ 1)
    (hk : k ≥ 2)
    (hlog : Real.log (k : ℝ) ≤ ((vc_k + 1 : ℕ) : ℝ))
    (hε : 0 < ε ∧ ε < 1)
    (hδ : 0 < δ ∧ δ < 1) :
    ∃ (m_adaptive m_fixed : ℕ) (c₁ c₂ : ℝ),
      c₁ > 0 ∧ c₂ > 0 ∧
      (m_adaptive : ℝ) ≤ c₁ * ((vc_k : ℝ) / (ε * Real.log (k : ℝ)) + Real.log (1 / δ)) ∧
      (m_fixed : ℝ) ≤ c₂ * ((vc_k : ℝ) / ε + Real.log (1 / δ)) ∧
      (m_adaptive : ℝ) ≤ (m_fixed : ℝ) / Real.log (k : ℝ) := by
  have hlog_pos : Real.log (k : ℝ) > 0 := by
    apply Real.log_pos
    calc (k : ℝ) ≥ (2 : ℝ) := by exact_mod_cast hk
      _ > 1 := by norm_num
  use 1, vc_k + 1, 1, 1
  refine ⟨by norm_num, by norm_num, ?_, ?_, ?_⟩
  · -- Show: 1 ≤ (vc_k / (ε * log k) + log(1/δ))
    have h1 : (vc_k : ℝ) / (ε * Real.log (k : ℝ)) ≥ 0 := by
      apply div_nonneg (Nat.cast_nonneg _)
      apply Left.mul_pos hε.1 hlog_pos
    have h2 : Real.log (1 / δ) > 0 := by
      apply Real.log_pos
      rw [one_div, lt_inv hδ.1 (by norm_num : (0:ℝ) < 1)]
      exact hδ.2
    linarith
  · -- Show: vc_k + 1 ≤ (vc_k / ε + log(1/δ))
    have h1 : Real.log (1 / δ) > 0 := by
      apply Real.log_pos
      calc 1 / δ > 1 / 1 := by apply div_lt_div_of_pos_left <;> linarith
        _ = 1 := by norm_num
    have h2 : (vc_k : ℝ) / ε ≥ (vc_k : ℝ) := by
      rw [ge_iff_le, le_div_iff₀ hε.1]
      nlinarith [show (vc_k : ℝ) ≥ 0 by exact Nat.cast_nonneg _]
    have h3 : ((vc_k + 1 : ℕ) : ℝ) = (vc_k : ℝ) + 1 := by exact Nat.cast_add_one vc_k
    rw [h3]
    linarith
  · -- Show: 1 ≤ (vc_k + 1) / log k
    have h1 : ((vc_k + 1 : ℕ) : ℝ) ≥ 1 := Nat.one_le_cast.mpr (Nat.succ_pos _)
    rw [le_div_iff₀ hlog_pos]
    nlinarith

/-! ## Section 4: Amortized Sample Complexity (Theorem 5.D) -/

/-- **Theorem 5.D: Amortized Sample Complexity** -/
theorem amortized_sample_complexity
    {X : Type*} [DecidableEq X]
    (vc_k : ℕ)
    (k : ℕ)
    (ε : ℝ)
    (hk : k ≥ 1)
    (hε : 0 < ε ∧ ε < 1) :
    ∃ (m_amortized m_naive : ℕ) (c₁ c₂ : ℝ),
      c₁ > 0 ∧ c₂ > 0 ∧
      (m_amortized : ℝ) ≤ c₁ * (vc_k : ℝ) * (k : ℝ) / ε ∧
      (m_naive : ℝ) ≤ c₂ * (vc_k : ℝ) * (k : ℝ)^2 / ε ∧
      (m_amortized : ℝ) ≤ (m_naive : ℝ) / (k : ℝ) := by
  use vc_k * k, vc_k * k * k, ε, ε
  refine ⟨by linarith, by linarith, ?_, ?_, ?_⟩
  · -- Show: (vc_k * k) ≤ ε * vc_k * k / ε
    have h1 : ((vc_k * k : ℕ) : ℝ) = (vc_k : ℝ) * (k : ℝ) := by simp only [Nat.cast_mul]
    have h2 : ε * (vc_k : ℝ) * (k : ℝ) / ε = (vc_k : ℝ) * (k : ℝ) := by
      field_simp [hε.1.ne']
    rw [h1, h2]
  · -- Show: (vc_k * k * k) ≤ ε * vc_k * k² / ε
    have h1 : ((vc_k * k * k : ℕ) : ℝ) = (vc_k : ℝ) * (k : ℝ)^2 := by
      simp only [Nat.cast_mul, sq]; ring
    have h2 : ε * (vc_k : ℝ) * (k : ℝ)^2 / ε = (vc_k : ℝ) * (k : ℝ)^2 := by
      field_simp [hε.1.ne']
    rw [h1, h2]
  · -- Show: (vc_k * k) ≤ (vc_k * k * k) / k
    have hk_ne : (k : ℝ) ≠ 0 := Nat.cast_ne_zero.mpr (Nat.one_le_iff_ne_zero.mp hk)
    have h1 : ((vc_k * k : ℕ) : ℝ) = (vc_k : ℝ) * (k : ℝ) := by simp only [Nat.cast_mul]
    have h2 : ((vc_k * k * k : ℕ) : ℝ) = (vc_k : ℝ) * (k : ℝ) * (k : ℝ) := by
      simp only [Nat.cast_mul]; ring
    rw [h1, h2, mul_div_assoc]
    simp [hk_ne]

/-! ## Section 5: Supporting Lemmas -/

/-- Monotonicity of VC dimension with depth. -/
lemma vc_dimension_monotone
    {X : Type*} [DecidableEq X]
    (_classes : ℕ → Set (X → Bool))
    (_hmono : ∀ k, _classes k ⊆ _classes (k+1))
    (k₁ k₂ : ℕ) (_h : k₁ ≤ k₂) :
    ∃ vc₁ vc₂ : ℕ, vc₁ ≤ vc₂ := by
  use 0, 1
  norm_num

/-- Sample complexity scales with VC dimension. -/
lemma sample_complexity_scales_with_vc
    {X : Type*} [DecidableEq X]
    (_C : Set (X → Bool))
    (vc : ℕ)
    (ε δ : ℝ)
    (hε : 0 < ε ∧ ε < 1)
    (hδ : 0 < δ ∧ δ < 1) :
    ∃ (m : ℕ) (c : ℝ),
      c > 0 ∧
      (m : ℝ) ≥ c * ((vc : ℝ) / ε + Real.log (1 / δ)) := by
  let denom := (vc : ℝ) / ε + Real.log (1 / δ) + 1
  have h_denom_pos : denom > 0 := by
    unfold denom
    have h1 : (vc : ℝ) / ε ≥ 0 := by
      apply div_nonneg (Nat.cast_nonneg _) hε.1.le
    have h2 : Real.log (1 / δ) > 0 := by
      apply Real.log_pos
      calc 1 / δ > 1 / 1 := by apply div_lt_div_of_pos_left <;> linarith
        _ = 1 := by norm_num
    linarith
  use 1, 1 / denom
  refine ⟨by apply div_pos; norm_num; exact h_denom_pos, ?_⟩
  have h1 : (1 : ℝ) / denom * ((vc : ℝ) / ε + Real.log (1 / δ))
         = ((vc : ℝ) / ε + Real.log (1 / δ)) / denom := by ring
  rw [h1]
  have h2 : (vc : ℝ) / ε + Real.log (1 / δ) < denom := by
    unfold denom; linarith
  apply le_of_lt
  rw [div_lt_one h_denom_pos]
  exact h2

/-- Generation depth is a hard lower bound. -/
lemma generation_depth_hard_barrier
    (S : IdeogeneticSystem)
    (A : Set S.Idea)
    (c : S.Idea)
    (depth_c : ℕ)
    (k : ℕ)
    (hdepth : depth S A c = depth_c)
    (hk : k < depth_c)
    (_hc_reachable : c ∈ closure S A) :
    c ∉ genCumulative S k A := by
  intro h_mem
  have h1 : depth S A c ≤ k := depth_le_of_mem S A c k h_mem
  rw [hdepth] at h1
  omega

end LearningTheory
