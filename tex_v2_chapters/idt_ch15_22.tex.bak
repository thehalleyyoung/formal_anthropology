  \node[synth] (s) at (2, 2.5) {$a \compose b$};

  \draw[opp] (t) -- node[below] {\small opposition} (at);
  \draw[comp] (t) -- node[left] {\small compose} (s);
  \draw[comp] (at) -- node[right] {\small compose} (s);

